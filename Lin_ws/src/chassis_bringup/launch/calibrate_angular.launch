<?xml version="1.0"?>
<launch>
    <!-- 启动角速度校准节点 -->
    <!-- Start angular velocity calibration node -->
    <node name="calibrate_angular" pkg="chassis_bringup" type="calibrate_angular.py" output="screen">
        <param name="odom_frame"      type="string" value="odom_combined"/> 
    </node>
</launch>

