<launch>

    <!-- 设置里程计话题起点TF坐标 -->
    <arg name="odom_frame_id"  default="odom_combined"/> 
    <!--选择cartogapher算法时不开启滤波节点-->
    <arg name="is_cartographer" default="false"/>
    <!--打开底盘驱动节点，初始化串口等操作-->
    <node pkg="chassis_bringup" type="chassis_drive_node" name="chassis_drive" output="screen" respawn="false" >
        <!-- <param name="usart_port_name"    type="string" value="//home/GGB/Lin_ws/pts/pts3"/>   -->
        <param name="usart_port_name"    type="string" value="//home/GGB/Lin_ws/pts/pts3"/> 
        <param name="serial_baud_rate"   type="int"    value="115200"/>
        <param name="odom_frame_id"      type="string" value="$(arg odom_frame_id)"/> 
        <param name="robot_frame_id"     type="string" value="base_footprint"/> 
        <param name="gyro_frame_id"      type="string" value="imu_link"/> 

        <!-- 里程计修正参数，对来自运动底盘的速度信息进行手动修正 -->
        <!-- 2026-03-09 校准：线性1m测试、角度360°测试 -->
        <param name="odom_x_scale"      type="double" value="2.18"/>
        <param name="odom_y_scale"      type="double" value="1.0"/>
        <param name="odom_z_scale_positive"      type="double" value="1.93"/>
        <param name="odom_z_scale_negative"      type="double" value="1.93"/> 
    </node>

    <!-- 发布用于建图、导航的TF关系与小车外形可视化 -->
    <include file="$(find robot_description)/launch/robot_model_visual.launch"/>

    <node pkg="robot_pose_ekf" type="robot_pose_ekf" name="robot_pose_ekf" unless="$(arg is_cartographer)">
        <param name="output_frame" value="odom_combined"/>
        <param name="base_footprint_frame" value="base_footprint"/>
        <param name="freq" value="10.0"/>
        <param name="sensor_timeout" value="1.0"/>
        <param name="odom_used" value="true"/>
        <param name="imu_used" value="false"/>
        <param name="vo_used" value="false"/>
    </node>

</launch>



